# LLM provider settings
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
UNCERTAINTY_SAMPLES=3

# Phase 2 JWT auth skeleton.
# Keep AUTH_ENABLED=false for Phase 1 demos unless Aria token passing is ready.
AUTH_ENABLED=false
JWT_ALGORITHM=HS256
JWT_SECRET=change-me-for-local-testing
JWT_PUBLIC_KEY=
JWT_ISSUER=aria
JWT_AUDIENCE=agile-mcp-server

# Use HS256 for local/demo only if Agile provides a shared secret.
# Use RS256/JWT_PUBLIC_KEY if Aria signs tokens with a private key.
# Never commit real secrets.
